<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="50dp"  app:cardElevation="4dp"      app:strokeWidth="0dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/logoo"
            android:scaleType="centerCrop"
            android:contentDescription="โลโก้โปรไฟล์" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="กำลังโหลดชื่อ..."
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvUserEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="กำลังโหลดอีเมล..."
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnEditName"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="✏️ แก้ไขชื่อผู้ใช้"
        android:textSize="16sp"
        android:textColor="#333333"
        android:backgroundTint="#EEEEEE"
        android:elevation="2dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnChangePassword"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🔑 เปลี่ยนรหัสผ่าน"
        android:textSize="16sp"
        android:textColor="#333333"
        android:backgroundTint="#EEEEEE"
        android:elevation="2dp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnResetData"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="🔄 รีเซ็ตข้อมูลรายรับ-รายจ่าย"
        android:textSize="16sp"
        android:textColor="#333333"
        android:backgroundTint="#FFEB3B"
        android:layout_marginBottom="30dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="ออกจากระบบ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF9800"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnDeleteAccount"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="ลบบัญชีผู้ใช้"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#F44336" />

</LinearLayout>